            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"The relationship between monetary policy and asset price inflation has been extensively studied in the literature. Central banks face a fundamental tension between their mandate for price stability and the unintended consequences of prolonged low interest rates on equity and real estate valuations.\",\n  \"creator_id\": \"demo_borderline\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/submit",
              "host": ["{{base_url}}"],
              "path": ["submit"]
